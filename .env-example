# ============================================
# HTPT Microservice Environment Variables
# (File mẫu - Hãy copy ra thành file .env)
# ============================================

# PostgreSQL
POSTGRES_USER=my_db_user
POSTGRES_PASSWORD=my_super_secret_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# JWT (Mã hoá token)
JWT_SECRET=your_base64_encoded_jwt_secret_key_here
JWT_EXPIRATION_MS=86400000

# Service Ports
GATEWAY_PORT=8080
USER_SERVICE_PORT=8081
PRODUCT_SERVICE_PORT=8082
ORDER_SERVICE_PORT=8083
INVENTORY_SERVICE_PORT=8084
NOTIFICATION_SERVICE_PORT=8085
FRONTEND_PORT=3000

# Frontend Variables
# (Thay địa chỉ IP dưới đây bằng IP External của Node K8s của bạn)
VITE_API_URL=http://YOUR_NODE_IP_HERE:30080/api
